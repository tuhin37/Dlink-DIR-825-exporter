# D-Link DIR-825 Exporter Configuration
# Copy to config.yaml and fill in your values
# config.yaml is in .gitignore - never commit credentials

router:
  host: "10.0.0.1"
  username: "admin"
  password: "your_password_here"
  # Credentials are only used for initial login via CPE JSON-RPC API
  # AccessToken is auto-renewed

exporter:
  listen_address: "0.0.0.0"
  listen_port: 9101  # Metrics port — Prometheus scrapes :9101/metrics
  scrape_interval: 60  # seconds between metric scrapes
  log_scrape_interval: 30  # seconds between syslog scrapes

logging:
  # Syslog output file - Promtail tails this to ship to Loki
  log_file: "/var/log/dlink/syslog.log"
  # Maximum log file size before rotation (bytes)
  log_max_size: 10485760  # 10MB
